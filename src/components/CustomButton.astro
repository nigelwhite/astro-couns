---
import PhoneIcon from "astro-feather-icons/Phone";
---

<div class="button-container">
  <div href="/contact" class="button">
    <div class="button-contents">
      <PhoneIcon class="button-icon" />

      Book a free call
    </div>
  </div>
</div>

<style lang="sass">
  .button-container
    height: 5rem
    margin-top: 4rem

    .button
      border-radius: 20px
      cursor: pointer
      font-size: 1.2rem
      width: 15rem
      padding: 1rem
      text-decoration: none

    .button-contents
      display: flex
      flex-direction: row
      justify-content: center
      align-items: center

  .button-icon
    margin-right: 1rem
</style>
